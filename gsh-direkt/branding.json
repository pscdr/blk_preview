    "buttonSecondary": {
      "background": "#BBBBBB",
      "textColor": "#FFFFFF",
      "borderRadius": "0px"
    }
  },
  "images": {
    "logo": "https://www.gsh-direkt.de/template/GSH/pix/logo.png",
    "favicon": "https://www.gsh-direkt.de/template/GSH/favicon.ico"
  },
  "personality": {
    "tone": "professional",
    "energy": "medium",
    "targetAudience": "business professionals"
  }
}